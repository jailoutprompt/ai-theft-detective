# AI 도난탐정 — 환경변수 예시
# 이 파일을 복사해서 .env 로 저장 후 값을 채워넣으세요
# cp .env.example .env
# Fly.io는 .env 파일 미사용 — fly secrets set 명령어로 주입 (DEPLOY.md 참고)

# OpenAI — 추후 GPT 유사도 분석 연동 시 필요
OPENAI_API_KEY=sk-...

# 공공데이터포털 CCTV API 키 (https://www.data.go.kr)
# 서울특별시_CCTV 현황 API 신청 후 발급
PUBLIC_DATA_API_KEY=

# 이메일 알림 (Resend — https://resend.com, 무료 100통/일)
RESEND_API_KEY=re_...

# 서비스 URL — 이메일 알림 내 링크 생성용
SITE_URL=https://noeullim-theft-ai.fly.dev

# 에러 모니터링 (Sentry — 선택)
SENTRY_DSN=

# 데이터베이스 (Fly.io 볼륨 마운트 시 /app/data 자동 사용 — 변경 불필요)
DATABASE_URL=sqlite:///data/theftdetective.db
SCHEDULER_DB=sqlite:///data/scheduler.db

# Rate Limit 기본값 (slowapi 형식)
RATE_LIMIT_DEFAULT=60/minute

# 실행 환경 (development / production)
ENV=development
